{
  "name": "trucklog",
  "version": "1.0.0",
  "description": "TruckLog – Virtual Trucking Company for ETS2",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:all": "electron-builder --win --mac --linux"
  },
  "build": {
    "appId": "com.trucklog.app",
    "productName": "TruckLog",
    "copyright": "TruckLog ETS2",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
     
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TruckLog"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "firebase": "^10.7.1"
  }
}
